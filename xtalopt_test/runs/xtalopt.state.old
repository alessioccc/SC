[xtalopt]
edit\description=test
edit\locWorkDir=/home/alessio-cucciari/Desktop/Programs/fhi-aims.250822/xtalopt_test/runs/
edit\logErrorDirs=false
edit\numOptSteps=1
edit\optimizer\0=generic
edit\optimizer\0\exeLocation=/home/alessio-cucciari/Desktop/Programs/fhi-aims.250822/xtalopt_test/bin/xtalopt_generic_exec.sh
edit\optimizer\0\generic\job.in="\n#!/usr/bin/env bash\n\nset -euo pipefail\nBASE=/home/alessio-cucciari/Desktop/Programs/fhi-aims.250822/xtalopt_test\n\nexport FHIAIMS=/home/alessio-cucciari/Desktop/Programs/fhi-aims.250822/bin/aims.x\n\nexport OMP_NUM_THREADS=1\nexport MKL_NUM_THREADS=1\nexport MKL_DYNAMIC=FALSE\nulimit -s unlimited\nexport NP=4\n\n# for quick tests: export NSTEPS=1 (or 2/3/4)\n\nexport NSTEPS=1\n\n# materialize structure from XtalOpt placeholder (IMPORTANT: no blank line inside heredoc)\ncat > POSCAR <<'EOF_POSCAR'\n%POSCAR%\nEOF_POSCAR\n\n# number of relaxation steps from XtalOpt user field (set user1 = 1..4)\n\nNSTEPS_RAW=\"%user1%\"\n\nif [[ \"$NSTEPS_RAW\" =~ ^[1-4]$ ]]; then\n\n  NSTEPS=\"$NSTEPS_RAW\"\n\nelse\n\n  NSTEPS=1\n\nfi\n\n\n# run FHI-aims workflow\n\nbash \"$BASE/bin/run_aims_4step_local.sh\" . \"$NSTEPS\"\n\n\n# parse result\n\nRES=$(python3 \"$BASE/bin/parse_aims_for_xtalopt.py\" --workdir . --mode energy)\n\n\n\n# write to XtalOpt expected output file\n\nOUTFILE=\"%filename%\"\n\n\nif [[ -d \"$OUTFILE\" || \"$OUTFILE\" == */ ]]; then\n\n\n  OUTDIR=$(echo \"$OUTFILE\" | sed 's:/*$::')\n\n  OUTFILE=\"$OUTDIR/job.out\"\n\nfi\n\ncat > \"$OUTFILE\" <<EOF_RES\n\n$RES\n\nEOF_RES\n"
edit\queueInterface\0=local
edit\remote\cancelJobAfterTime=false
edit\remote\cleanRemoteOnStop=false
edit\remote\host=
edit\remote\hoursForCancelJobAfterTime=100
edit\remote\port=22
edit\remote\queueRefreshInterval=10
